# Copy this file to .env for local development.
# Never commit the real .env file.

NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Runtime storage location.
# Local default is ./data if DATA_DIR is not set.
# Container default should usually be /app/data.
DATA_DIR=/app/data

# Optional path to scanner config.
# Container default should usually be /app/config/scanner.config.json.
SCANNER_CONFIG_PATH=/app/config/scanner.config.json
